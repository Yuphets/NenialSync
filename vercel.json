{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/media/(.*)", "dest": "/public/media/$1" },
    { "src": "/sw.js", "dest": "/public/sw.js", "headers": { "Cache-Control": "public, max-age=0, must-revalidate" } },
    { "src": "/manifest.webmanifest", "dest": "/public/manifest.webmanifest" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
