APP_NAME=Nenial
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Manila
VAT_RATE=0.12
PRICES_INCLUDE_VAT=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# Alternatively set DATABASE_URL to the pooled Neon connection string.
# DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require
DB_HOST=ep-your-neon-host.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Customer email verification.
# Do not copy placeholder values to Vercel. Use either real SMTP credentials
# from your mail provider, or RESEND_API_KEY plus a verified MAIL_FROM_ADDRESS.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_USERNAME=real-smtp-username
# MAIL_PASSWORD=real-smtp-password-or-app-password
# MAIL_SCHEME=smtp
# Use MAIL_SCHEME=smtps with MAIL_PORT=465.
# Optional production fallback: if RESEND_API_KEY is present, OTP email is sent via Resend API.
RESEND_API_KEY=

# Google OAuth
# Authorized redirect URI must exactly match: ${APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Hosted payments. Never expose these server-side keys to Vite/browser variables.
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=
MAYA_PUBLIC_KEY=
MAYA_SECRET_KEY=
MAYA_BASE_URL=https://pg-sandbox.paymaya.com
MAYA_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SEED_ADMIN_PASSWORD=ChangeMeAdmin2026!
SEED_ASSISTANT_PASSWORD=ChangeMeAssistant2026!
SEED_CASHIER_PASSWORD=ChangeMeCashier2026!

# Store-local offline mode (enable only on the LAN server)
LOCAL_OFFLINE_MODE=false
LOCAL_NODE_ID=store-main
CLOUD_URL=https://nenialsync.vercel.app
SYNC_SHARED_SECRET=
SYNC_TIMEOUT=20
